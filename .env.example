# --- Required for the Analysis tab (fundamentals via FMP) ---
# Get a free key at https://site.financialmodelingprep.com/developer (250 req/day)
VITE_FMP_API_KEY=your_fmp_key_here

# --- Optional ---
# News feed (NewsAPI.org). When unset the app shows curated mock headlines.
VITE_NEWS_API_KEY=your_newsapi_key_here

# Override the default CORS proxy chain for Yahoo Finance.
# Default: "https://api.allorigins.win/raw?url=,https://corsproxy.io/?url="
# VITE_CORS_PROXY=https://corsproxy.io/?url=

# Legacy — only used by older code paths; safe to leave blank.
VITE_ALPHA_VANTAGE_KEY=demo
VITE_TWELVEDATA_API_KEY=
